module Docscribe
  module InlineRewriter
    module DocBlock
      class Entry
        attr_accessor kind: Symbol
        attr_accessor tag: String
        attr_accessor lines: Array[String]
        attr_accessor subject: String?
        attr_accessor option_owner: String?
        attr_accessor generated: bool
        attr_accessor index: Integer

        def initialize: (?kind: Symbol, ?tag: String, ?lines: Array[String], ?subject: String?, ?option_owner: String?, ?generated: bool, ?index: Integer) -> void
      end

      def self?.merge: (Array[String] existing_lines, missing_lines: Array[String], sort_tags: bool, tag_order: Array[String], ?filter_existing: ::Hash[Symbol, untyped]) -> Array[String]

      def self?.parse_generated: (Array[String] lines, tag_order: Array[String]) -> Array[Entry]

      def self?.filter_existing_entries: (Array[Entry] entries, ::Hash[Symbol, untyped] filter_existing) -> Array[Entry]

      def self?.filter_param_entry?: (Entry entry, Array[String] param_names) -> bool

      def self?.filter_return_entry?: (Entry entry, bool filter_return) -> bool

      def self?.parse: (Array[String] lines, tag_order: Array[String]) -> Array[Entry]

      def self?.parse_lines: (Array[String] lines, Array[String] sortable_tags, entries: Array[Entry], index: Integer) -> Array[Entry]

      def self?.parse_one_line: (Array[String] lines, Integer idx, Array[String] sortable_tags, Array[Entry] entries, Integer index) -> Integer

      def self?.build_other_entry: (String line, Integer index) -> Entry

      def self?.sort: (Array[Entry] entries, tag_order: Array[String]) -> Array[Entry]

      def self?.sort_loop: (Array[Entry] entries, Array[Entry] out, ::Hash[String, Integer] priority) -> void

      def self?.consume_tag_run: (Array[Entry] entries, Integer idx) -> [Array[Entry], Integer]

      def self?.render: (Array[Entry] entries) -> Array[String]

      def self?.sort_run: (Array[Entry] entries, priority: ::Hash[String, Integer]) -> Array[Entry]

      def self?.build_groups: (Array[Entry] entries) -> Array[Array[Entry]]

      def self?.group_entries_loop: (Array[Entry] entries, Array[Array[Entry]] groups) -> void

      def self?.group_one_entry: (Array[Entry] entries, Integer idx, Array[Array[Entry]] groups) -> Integer

      def self?.build_param_group: (Array[Entry] entries, Integer idx, Entry entry) -> Array[Entry]

      def self?.group_priority: (Array[Entry] group, ::Hash[String, Integer] priority) -> Integer

      def self?.build_priority: (Array[String] tag_order) -> ::Hash[String, Integer]

      def self?.normalized_tag_order: (Array[String] tag_order) -> Array[String]

      def self?.consume_tag_entry: (Array[String] lines, Integer start_idx, index: Integer, sortable_tags: Array[String]) -> [Entry, Integer]

      def self?.collect_continuation_lines: (Array[String] lines, Integer start_idx, String first, Array[String] sortable_tags) -> Array[String]

      def self?.add_continuation_lines: (Array[String] lines, Integer start_idx, Array[String] result, Array[String] sortable_tags) -> void

      def self?.continuation_candidate?: (String line, Array[String] sortable_tags) -> bool

      def self?.build_tag_entry: (String first, String tag, Array[String] entry_lines, Integer index) -> Entry

      def self?.extract_subject: (String line, String? tag) -> String?

      def self?.extract_param_name: (String line) -> String?

      def self?.name_after_bracket: (String rest, Integer type_end) -> String?

      def self?.matching_close_bracket: (String str) -> Integer?

      def self?.extract_option_owner: (String line) -> String?

      def self?.sortable_top_level_tag_line?: (String line, Array[String] sortable_tags) -> bool

      def self?.extract_tag: (String line) -> String?

      def self?.top_level_tag_line?: (String line) -> bool

      def self?.comment_line?: (String line) -> bool

      def self?.blank_comment_line?: (String line) -> bool

      def self?.continuation_comment_line?: (String line) -> bool
    end
  end
end
