module Docscribe
  module CLI
    module Run
      INITIAL_RUN_STATE: { changed: false, had_errors: false, checked_ok: 0, checked_fail: 0, corrected: 0, fail_paths: Array[String], fail_changes: Hash[String, Array[Hash[Symbol, untyped]]], error_paths: Array[String], error_messages: Hash[String, String], type_mismatch_paths: Array[String], type_mismatch_changes: Hash[String, Array[Hash[Symbol, untyped]]] }

      def self.run: (options: Hash[Symbol, untyped], argv: Array[String]) -> Integer

      def self.build_config: (Hash[Symbol, untyped] options) -> Docscribe::Config

      def self.run_stdin: (options: Hash[Symbol, untyped], conf: Docscribe::Config) -> Integer

      def self.stdin_rewrite_result: (Hash[Symbol, untyped] options, Docscribe::Config conf) -> Hash[Symbol, untyped]

      def self.core_rbs_provider_for: (Docscribe::Config conf) -> (untyped | nil)

      def self.filtered_paths: (Array[String] argv, Docscribe::Config conf) -> Array[String]

      def self.no_files_found: () -> 1

      def self.expand_paths: (Array[String] args) -> Array[String]

      def self.append_expanded_path: (Array[String] files, String path) -> void

      def self.run_files: (options: Hash[Symbol, untyped], conf: Docscribe::Config, paths: Array[String]) -> Integer

      private

      def self.finalize_run: (Hash[Symbol, untyped] options, Hash[Symbol, untyped] state) -> void

      def self.run_exit_code: (Hash[Symbol, untyped] options, Hash[Symbol, untyped] state) -> (1 | 0)

      def self.initial_run_state: () -> Hash[Symbol, untyped]

      def self.process_one_file: (String path, options: Hash[Symbol, untyped], conf: Docscribe::Config, pwd: Pathname, state: Hash[Symbol, untyped]) -> void

      def self.dispatch_file_result: (String path, src: String, out: String, file_changes: Array[Hash[Symbol, untyped]], **Hash[Symbol, untyped] ctx) -> void

      def self.display_path_for: (String path, pwd: Pathname) -> String

      def self.read_source_for_path: (String path, display_path: String, options: Hash[Symbol, untyped], state: Hash[Symbol, untyped]) -> (String | nil)

      def self.rewrite_result_for_path: (String path, src: String, ctx: Hash[Symbol, untyped]) -> (Hash[Symbol, untyped] | nil)

      def self.record_rewrite_error: (String path, untyped error, Hash[Symbol, untyped] ctx) -> void

      def self.handle_check_result: (String path, src: String, out: String, file_changes: Array[Hash[Symbol, untyped]], **Hash[Symbol, untyped] ctx) -> void

      def self.type_mismatch_changes: (Array[Hash[Symbol, untyped]] file_changes) -> Array[Hash[Symbol, untyped]]

      def self.handle_check_no_changes: (String path, type_mismatches: Array[Hash[Symbol, untyped]], display_path: String, options: Hash[Symbol, untyped], state: Hash[Symbol, untyped]) -> void

      def self.handle_check_failed: (String path, file_changes: Array[Hash[Symbol, untyped]], display_path: String, options: Hash[Symbol, untyped], state: Hash[Symbol, untyped]) -> void

      def self.handle_write_result: (String path, src: String, out: String, file_changes: Array[Hash[Symbol, untyped]], **Hash[Symbol, untyped] ctx) -> void

      def self.log_write_verdict: (String verdict, String display_path, Array[Hash[Symbol, untyped]] file_changes, Hash[Symbol, untyped] options) -> void

      def self.print_check_explanations: (Array[Hash[Symbol, untyped]] file_changes, Hash[Symbol, untyped] options) -> void

      def self.record_write_error: (String path, untyped error, display_path: String, options: Hash[Symbol, untyped], state: Hash[Symbol, untyped]) -> void

      def self.log_check_verdict: (String verdict, String display_path, Hash[Symbol, untyped] options) -> void

      def self.print_check_summary: (state: Hash[Symbol, untyped], options: Hash[Symbol, untyped]) -> void

      def self.print_check_status_line: (Hash[Symbol, untyped] state) -> void

      def self.all_fine?: (Hash[Symbol, untyped] state, Integer checked_error, Integer type_mismatch_count) -> bool

      def self.mismatch_only?: (Hash[Symbol, untyped] state, Integer checked_error) -> bool

      def self.build_failure_line: (Hash[Symbol, untyped] state, Integer type_mismatch_count, Integer checked_error) -> String

      public

      def self.print_fail_paths: (Hash[Symbol, untyped] state, Hash[Symbol, untyped] options) -> void

      def self.print_type_mismatch_paths: (Hash[Symbol, untyped] state, Hash[Symbol, untyped] options) -> void

      def self.format_change_reason: (Hash[Symbol, untyped] change) -> String

      def self.change_line_suffix: (Hash[Symbol, untyped] change) -> String

      def self.change_method_suffix: (Hash[Symbol, untyped] change) -> String

      def self.direct_message_change?: (Hash[Symbol, untyped] change) -> bool

      def self.print_write_summary: (state: Hash[Symbol, untyped]) -> void

      def self.print_error_paths: (Hash[Symbol, untyped] state) -> void
    end
  end
end
