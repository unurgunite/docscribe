      def self.handle_check_failed: (String path, file_changes: Array[Formatters::change], display_path: String, options: Formatters::opts, state: Formatters::state) -> void

      def self.handle_write_result: (String path, src: String, out: String, file_changes: Array[Formatters::change], **untyped ctx) -> void

