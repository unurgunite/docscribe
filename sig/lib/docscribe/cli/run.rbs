      def self.print_check_explanations: (Array[Formatters::change] file_changes) -> void

      def self.record_write_error: (String path, untyped error, display_path: String, options: Formatters::opts, state: Formatters::state) -> void

      def self.log_check_verdict: (String verdict, String display_path, Formatters::opts options) -> void

      def self.print_check_summary: (state: Formatters::state, options: Formatters::opts) -> void

      def self.print_check_status_line: (Formatters::state state) -> void

      def self.all_fine?: (Formatters::state state, Integer checked_error, Integer type_mismatch_count) -> bool

      def self.mismatch_only?: (Formatters::state state, Integer checked_error) -> bool

      def self.build_failure_line: (Formatters::state state, Integer type_mismatch_count, Integer checked_error) -> String

